{% extends "layouts/admin.twig" %}
{% block content %}
    {{ veiculos.marca }}
    <!-- Main Content -->
    <div class="main-content">                    <!-- Página Content -->
                    <main class="page-content">
                        <div class="container-fluid">
                            <div class="row mb-4">
                                <div class="col-12">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h2>
                                                Gerenciar Automóveis
                                            </h2>
                                            <p class="text-muted">
                                                Controle de inventário de automóveis
                                            </p>
                                        </div>
                                        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addVehicleModal">
                                            <i class="bi bi-plus-circle"></i>
                                            Adicionar Automóvel
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <!-- Filters -->
                            <div class="card card-body mb-4 border-0 shadow-sm">
                                <form action="/admin/automoveis/busca/" method="get" class="row g-3 align-items-end">
                                    <!-- BUSCA -->
                                    <div class="col-md-4 col-lg-4">
                                        <label class="form-label small fw-bold">
                                            Pesquisa
                                        </label>
                                        <input type="text" class="form-control" name="nome" value=" {{ filtros.nome }} " placeholder="Modelo"></div>

                                        <!-- STATUS -->
                                        <div class="col-md-3 col-lg-2">
                                            <label class="form-label small fw-bold">
                                                Status
                                            </label>
                                            <select name="status" class="form-select">
                                                <option value="">
                                                    Todos
                                                </option>
                                                <option value="Disponivel" {{ filtros.status == 'Disponivel' ? 'selected' : '' }}>
                                                    Disponível
                                                </option>
                                                <option value="Negociacao" {{ filtros.status == 'Negociacao' ? 'selected' : '' }}>
                                                    Em Negociação
                                                </option>
                                                <option value="Vendido" {{ filtros.status == 'Vendido' ? 'selected' : '' }}>
                                                    Vendido
                                                </option>
                                                <option value="Publicado" {{ filtros.status == 'Public' ? 'selected' : '' }}>
                                                    Publicado
                                                </option>
                                                <option value="indisponivel" {{ filtros.status == 'indisponivel' ? 'selected' : '' }}>
                                                    Indisponível
                                                </option>
                                            </select>
                                        </div>

                                        <!-- MARCA -->
                                        <div class="col-md-3 col-lg-3">
                                            <label class="form-label small fw-bold">
                                                Marca
                                            </label>
                                            <select name="id_marca" class="form-control">
                                                <option value="">
                                                    Filtrar por Marca
                                                </option>
                                                {% for marca in marcas %}
                                                    <option value="{{ marca.id }}" {{ filtros.id_marca == marca.id ? 'selected' : '' }}>
                                                        {{ marca.nome }}
                                                    </option>
                                                {% endfor %}
                                            </select>
                                        </div>

                                        <!-- BOTÃO -->
                                        <div class="col-md-2 col-lg-3">
                                            <button type="submit" class="btn btn-primary w-100">
                                                <i class="bi bi-search"></i>
                                                Buscar
                                            </button>
                                        </div>
                                    </form>
                                </div>

                                <!-- Vehicles Table -->
                                <div class="card">
                                    <div class="table-responsive">
                                        <table class="table mb-0">
                                            <thead>
                                                <tr>
                                                     <th>
                                                        Codigo
                                                    </th>
                                                    <th style="width: 100px;">
                                                        Foto
                                                    </th>
                                                    <th>
                                                        Modelo
                                                    </th>
                                                    <th>
                                                        Ano
                                                    </th>
                                                    <th>
                                                        Preço (AOA)
                                                    </th>
                                                    <th>
                                                        Status
                                                    </th>
                                                    <th style="width: 120px;">
                                                        Ações
                                                    </th>
                                                </tr>
                                            </thead>
                                            <tbody>

                                                <tbody>
                                                    {% for veiculo in veiculos %}

                                                        <tr>
                                                            <td>
                                                                {{ veiculo.id }}
                                                            </td>
                                                            
                                                            <td>
                                                                <!-- Imagem principal do veículo -->
                                                                <img src="{{ carImage(veiculo.imagens[0] ?? 'default.jpg') }}" alt="{{ veiculo.modelo }}" class="rounded" style="width: 80px; height: 60px; object-fit: cover;"></td>
                                                                <td>
                                                                    <strong>
                                                                        {{ veiculo.modelo }}
                                                                    </strong>
                                                                    <br>
                                                                        <small class="text-muted">
                                                                            {{ veiculo.transmissao }}
                                                                            |
                                                                            {{ veiculo.cor }}
                                                                        </small>
                                                                    </td>
                                                                    <td>
                                                                        {{ veiculo.ano }}
                                                                    </td>
                                                                    <td>
                                                                        {{ veiculo.preco|number_format(2, ',', '.') }}
                                                                    </td>
                                                                    <td>
                                                                        {% if veiculo.status|lower == 'disponivel' %}
                                                                            <span class="badge bg-success">
                                                                                {{ veiculo.status }}
                                                                            </span>
                                                                        {% else %}
                                                                            <span class="badge bg-secondary">
                                                                                {{ veiculo.status }}
                                                                            </span>
                                                                        {% endif %}
                                                                    </td>
                                                                    <td>
                                                                        <div class="btn-group btn-group-sm" role="group">
                                                                            <a href="/admin/automoveis/show/{{ veiculo.id }}" class="btn btn-outline-info" title="Ver Detalhes">
                                                                                <i class="bi bi-eye"></i>
                                                                            </a>
                                                                        </button>
                                                                        <a href="/admin/automoveis/delete/{{ veiculo.id }}" class="btn btn-outline-danger" onclick="return confirm('Tem certeza que deseja apagar este veículo?')">
                                                                            <i class="bi bi-trash"></i>
                                                                        </a>
                                                                    </div>
                                                                </td>
                                                            </tr>
                                                        {% else %}
                                                            <tr>
                                                                <td colspan="6" class="text-center">
                                                                    Nenhum automóvel encontrado.
                                                                </td>
                                                            </tr>
                                                        {% endfor %}
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </main>
                            </div>

                            <!-- Add Vehicle Modal -->
                            <div class="modal fade" id="addVehicleModal" tabindex="-1">
                                <div class="modal-dialog modal-lg">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title">
                                                Adicionar Novo Automóvel
                                            </h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body">
                                            <form action="/admin/automoveis" method="POST" enctype="multipart/form-data">

                                                <div class="row">

                                                    <!-- MARCA -->
                                                    <div class="col-md-6 mb-3">
                                                        <label class="form-label">
                                                            Marca
                                                        </label>

                                                        <select name="id_marca" class="form-select" required>
                                                            <option value="">
                                                                Selecione a marca
                                                            </option>

                                                            {% for marca in marcas %}
                                                                <option value="{{ marca.id }}">
                                                                    {{ marca.nome }}
                                                                </option>
                                                            {% endfor %}
                                                        </select>
                                                    </div>

                                                    <!-- Categoria -->
                                                    <div class="col-md-6 mb-3">
                                                        <label class="form-label">
                                                            Categoria
                                                        </label>

                                                        <select name="id_categoria" class="form-select" required>
                                                            <option value="">
                                                                Selecione a categoria
                                                            </option>

                                                            {% for categoria in categorias %}
                                                                <option value="{{ categoria.id }}">
                                                                    {{ categoria.nome }}
                                                                </option>
                                                            {% endfor %}
                                                        </select>
                                                    </div>

                                                    <!-- MODELO -->
                                                    <div class="col-md-6 mb-3">
                                                        <label class="form-label">
                                                            Modelo
                                                        </label>
                                                        <input type="text" name="modelo" class="form-control" placeholder="Ex: Corolla" required></div>
                                                    </div>

                                                    <div class="row">

                                                        <!-- ANO -->
                                                        <div class="col-md-4 mb-3">
                                                            <label class="form-label">
                                                                Ano
                                                            </label>
                                                            <input type="number" name="ano" class="form-control" placeholder="2024" required></div>

                                                            <!-- COR -->
                                                            <div class="col-md-4 mb-3">
                                                                <label class="form-label">
                                                                    Cor
                                                                </label>
                                                                <input type="text" name="cor" class="form-control" placeholder="Branco" required></div>

                                                                <!-- TRANSMISSÃO -->
                                                                <div class="col-md-4 mb-3">
                                                                    <label class="form-label">
                                                                        Transmissão
                                                                    </label>
                                                                    <select name="transmissao" class="form-select" required>
                                                                        <option value="">
                                                                            Selecione
                                                                        </option>
                                                                        <option value="Automatica">
                                                                            Automática
                                                                        </option>
                                                                        <option value="Manual">
                                                                            Manual
                                                                        </option>
                                                                    </select>
                                                                </div>
                                                            </div>

                                                            <div class="row">

                                                                <!-- PREÇO -->
                                                                <div class="col-md-6 mb-3">
                                                                    <label class="form-label">
                                                                        Preço (AOA)
                                                                    </label>
                                                                    <input type="number" name="preco" class="form-control" placeholder="0.00" step="0.01" required></div>

                                                                    <!-- STATUS -->
                                                                    <div class="col-md-6 mb-3">
                                                                        <label class="form-label">
                                                                            Status
                                                                        </label>
                                                                        <select name="status" class="form-select" required>
                                                                            <option value="">
                                                                                Selecione
                                                                            </option>
                                                                            <option value="Disponivel">
                                                                                Disponível
                                                                            </option>
                                                                            <option value="Negociacao">
                                                                                Em Negociação
                                                                            </option>
                                                                            <option value="Vendido">
                                                                                Vendido
                                                                            </option>
                                                                            <option value="Publicado">
                                                                                Publicado
                                                                            </option>
                                                                        </select>
                                                                    </div>

                                                                </div>

                                                                <!-- QUILOMETRAGEM -->
                                                                <div class="mb-3">
                                                                    <label class="form-label">
                                                                        Quilometragem
                                                                    </label>
                                                                    <input type="number" name="quilometragem" class="form-control" placeholder="15000" required></div>

                                                                    <!-- COMBUSTIVEL -->
                                                                    <div class="mb-3">
                                                                        <label class="form-label">
                                                                            Combustível
                                                                        </label>
                                                                        <select name="combustivel" class="form-select" required>
                                                                            <option value="">
                                                                                Selecione
                                                                            </option>
                                                                            <option value="Gasolina">
                                                                                Gasolina
                                                                            </option>
                                                                            <option value="Diesel">
                                                                                Diesel
                                                                            </option>
                                                                            <option value="Eletrico">
                                                                                Elétrico
                                                                            </option>
                                                                            <option value="Hibrido">
                                                                                Híbrido
                                                                            </option>
                                                                        </select>
                                                                    </div>

                                                                    <!-- DESCRIÇÃO -->
                                                                    <div class="mb-3">
                                                                        <label class="form-label">
                                                                            Descrição
                                                                        </label>
                                                                        <textarea name="descricao" class="form-control" rows="3" placeholder="Detalhes adicionais..." required></textarea>
                                                                    </div>

                                                                    <!-- FOTO -->
                                                                    <div class="mb-3">
                                                                        <label class="form-label">
                                                                            Foto do Automóvel
                                                                        </label>
                                                                        <input type="file" name="fotos[]" class="form-control" multiple accept="image/*" required></div>
                                                                        <div class="form-check">
                                                                            <input class="form-check-input" type="checkbox" value="1" name="destaque" id="destaqueCheck">
                                                                                <label class="form-check-label" for="destaqueCheck">
                                                                                    Destacar este automóvel
                                                                                </label>
                                                                            </div>
                                                                        </div>
                                                                        <div class="modal-footer">
                                                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                                                                Cancelar
                                                                            </button>
                                                                            <!-- BOTÃO -->
                                                                            <button type="submit" class="btn btn-primary">
                                                                                Cadastrar Automóvel
                                                                            </button>
                                                                        </div>

                                                                    </div>
                                                                </div>
                                                            </form>
                                                        </div>

                                                    {% endblock %}
                                                    