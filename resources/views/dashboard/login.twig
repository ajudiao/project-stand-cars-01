<!DOCTYPE html>
<html lang="pt">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>Entrar - Saeld Auto</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f5f6f8;
            font-family: Arial, Helvetica, sans-serif;
        }

        .login-container {
            max-width: 900px;
            width: 100%;
            background: #fff;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.12);
        }

        .car-side {
            background: url("https://images.unsplash.com/photo-1503376780353-7e6692767b70") center/cover no-repeat;
            min-height: 500px;
        }

        .logo {
            font-size: 26px;
            font-weight: 600;
        }

        .input-group-text {
            background: #f1f3f5;
            border-right: 0;
        }

        .form-control {
            border-left: 0;
        }

        .btn-dark {
            padding: 10px;
        }
    </style>

</head>

<body>

    <div class="login-container">

        <div class="row g-0">

            <!-- FORM -->
            <div class="col-md-6 p-5 d-flex flex-column justify-content-center">

                <div class="mb-4">
                    <h3 class="logo">
                        <i class="bi bi-car-front-fill"></i> Saeld Auto
                    </h3>
                    <p class="text-muted">Sistema de Gestão</p>
                </div>

                <form action="/admin/login" method="POST">

                    <div class="mb-3">
                        <label class="form-label">Email</label>

                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-envelope"></i>
                            </span>

                            <input type="email" class="form-control" name="email" placeholder="Digite o seu email">
                        </div>

                    </div>

                    <div class="mb-2">
                        <label class="form-label">Senha</label>

                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-lock"></i>
                            </span>

                            <input type="password" class="form-control" name="password" placeholder="Digite a sua senha">
                        </div>

                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-3">

                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="lembrar">
                            <label class="form-check-label" for="lembrar">Lembrar-me</label>
                        </div>

                        <a href="recuperar-senha.html" class="text-decoration-none small">
                            <i class="bi bi-question-circle"></i> Esqueci a senha
                        </a>

                    </div>
                    <p class="text-danger text-center m-2">{{ error }}</p>
                    <button class="btn btn-dark w-100">
                        <i class="bi bi-box-arrow-in-right"></i> Entrar
                    </button>

                </form>

            </div>

            <!-- IMAGEM -->
            <div class="col-md-6 car-side d-none d-md-block"></div>

        </div>

    </div>

</body>

</html>