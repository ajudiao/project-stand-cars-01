{% extends "layouts/admin.twig" %}
    {% block content %}
        <!-- Main Content -->
        <div class="main-content">            <!-- Página Content -->
            <main class="page-content">
                <div class="container-fluid">
                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h2>Histórico de Vendas</h2>
                                    <p class="text-muted">Acompanhe todas as vendas realizadas</p>
                                </div>
                                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addSaleModal">
                                    <i class="bi bi-plus-circle"></i> Registrar Venda
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Stats -->
                    <div class="row g-4 mb-4">
                        <div class="col-md-6 col-lg-3">
                            <div class="card stat-card">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="stat-icon bg-success">
                                            <i class="bi bi-check-circle"></i>
                                        </div>
                                        <div class="ms-3">
                                            <h6 class="text-muted mb-0">Vendas Concluídas</h6>
                                            <h3 class="mb-0">
                                                {{ total_concluidas }}
                                            </h3>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-3">
                            <div class="card stat-card">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="stat-icon bg-info">
                                            <i class="bi bi-hourglass-split"></i>
                                        </div>
                                        <div class="ms-3">
                                            <h6 class="text-muted mb-0">Em Negociação</h6>
                                            <h3 class="mb-0">5</h3>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-3">
                            <div class="card stat-card">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="stat-icon bg-warning">
                                            <i class="bi bi-calendar-event"></i>
                                        </div>
                                        <div class="ms-3">
                                            <h6 class="text-muted mb-0">Este Mês</h6>
                                            <h3 class="mb-0">6</h3>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-3">
                            <div class="card stat-card">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="stat-icon bg-primary">
                                            <i class="bi bi-cash-coin"></i>
                                        </div>
                                        <div class="ms-3">
                                            <h6 class="text-muted mb-0">Faturamento</h6>
                                            <h3 class="mb-0">1.2M Kzs</h3>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                       <!-- Filters -->
                            <div class="card card-body mb-4 border-0 shadow-sm">
                                <form action="/admin/vendas/busca/" method="get" class="row g-3 align-items-end">
                                    <!-- BUSCA -->
                                    <div class="col-md-4 col-lg-4">
                                        <label class="form-label small fw-bold">
                                            Pesquisa
                                        </label>
                                        <input type="text" class="form-control" name="nome" placeholder="Nome do cliente ou veiculo" value="{{ filtros.nome ?? '' }}">
                                    </div>

                                        <!-- STATUS -->
                                        <div class="col-md-3 col-lg-4">
                                            <label class="form-label small fw-bold">
                                                Status
                                            </label>
                                            <select name="status" class="form-select">
                                                <option value="">
                                                    Todos
                                                </option>
                                                <option value="Concluido" {{ filtros.status == 'Concluido' ? 'selected' : '' }}>
                                                    Concluído
                                                </option>
                                                <option value="Pendente" {{ filtros.status == 'Pendente' ? 'selected' : '' }}>
                                                    Pendente
                                                </option>
                                
                                            </select>
                                        </div>

                                        <!-- BOTÃO -->
                                        <div class="col-md-2 col-lg-4">
                                            <button type="submit" class="btn btn-primary w-100">
                                                <i class="bi bi-search"></i>
                                                Buscar
                                            </button>
                                        </div>
                                    </form>
                                </div>

                    <!-- Sales Table -->
                    <div class="card">
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th>Cliente</th>
                                        <th>Automóvel</th>
                                        <th>Valor</th>
                                        <th>Data</th>
                                        <th>Status</th>
                                        <th style="width: 100px;">Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tbody>
            {% for venda in vendas %}
                <tr>
            <td>{{ venda.cliente ?? venda.id_cliente }}</td>
            <td>{{ venda.marca }} {{ venda.modelo }}</td>
            <td>{{ venda.preco_venda|number_format(2, ',', '.') }}</td>
            <td>{{ venda.data_venda }}</td>
            <td>
                <span class="badge 
                    {% if venda.status == 'Concluido' %}
                        bg-success
                    {% elseif venda.status == 'Pendente' %}
                        bg-warning
                    {% else %}
                        bg-secondary
                    {% endif %}
                ">
                    {{ venda.status }}
                </span>
            </td>
            <td class="d-flex gap-2">
                <a href="/admin/vendas/show/{{ venda.id }}" class="btn btn-sm btn-outline-info">
                    <i class="bi bi-eye"></i>
                </a>
                {% if isAdmin %}
                <a href="/admin/vendas/delete/{{ venda.id }}" class="btn btn-sm btn-outline-danger" onclick="return confirm('Tem certeza que deseja excluir esta venda?')">
                    <i class="bi bi-trash"></i>
                </a>
                {% else %}
                <a href="javascript:void(0);" class="btn btn-sm btn-outline-secondary disabled" aria-disabled="true" title="Somente administrador pode excluir">
                    <i class="bi bi-trash"></i>
                </a>
                {% endif %}
            </td>
        
        </tr>
    {% else %}
        <tr>
            <td colspan="6" class="text-center">Nenhuma venda encontrada</td>
        </tr>
    {% endfor %}
</tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </main>
        </div>

    <!-- Add Sale Modal -->
    <div class="modal fade" id="addSaleModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Registrar Nova Venda</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="addSaleForm" action="/admin/vendas" method="POST">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Cliente</label>
                                <select class="form-select" name="id_cliente" required>
                                    <option value="">Selecione um cliente</option>
                                    {% for cliente in clientes %}
                                    <option value="{{ cliente.id }}">{{ cliente.nome_completo }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Automóvel</label>
                                <select class="form-select" name="id_veiculo" required>
                                    <option value="">Selecione um automóvel</option>
                                    {% for veiculo in veiculos %}
                                    <option value="{{ veiculo.id }}">
                                         {{ veiculo.marca }} {{ veiculo.modelo }} ({{ veiculo.ano }})
                                      </option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Desconto</label>
                                <input type="number" name="desconto" class="form-control" value="0.00" placeholder="0.00">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Valor</label>
                                <input type="number" name="valor" class="form-control" placeholder="0.00" required>
                            </div>
                            
                        </div>
                         
                        <div class="mb-3">
                            <label class="form-label">Status</label>
                            <select class="form-select" name="status" required>
                                <option value="Concluida">Concluída</option>
                                <option value="Pendente">Pendente</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Observações</label>
                            <textarea class="form-control" name="observacoes" rows="3" placeholder="Notas da venda..."></textarea>
                        </div>
                                
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                            <button type="submit" class="btn btn-primary">Registrar Venda</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Sale Modal -->
    <div class="modal fade" id="editSaleModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Detalhes da Venda</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="editSaleForm">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Cliente</label>
                                <input type="text" class="form-control" value="Carlos Mendes" disabled>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Automóvel</label>
                                <input type="text" class="form-control" value="Toyota Corolla 2024" disabled>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Valor</label>
                                <input type="number" class="form-control" value="95000" placeholder="0.00">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Data da Venda</label>
                                <input type="date" class="form-control" value="2024-02-15">
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Status</label>
                            <select class="form-select">
                                <option value="1" selected>Concluída</option>
                                <option value="2">Pendente</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Observações</label>
                            <textarea class="form-control" rows="3" placeholder="Notas da venda..."></textarea>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>
                    <button type="button" class="btn btn-primary" onclick="updateSale()">Salvar Alterações</button>
                </div>
            </div>
        </div>
    </div>

{% endblock %}