{% extends "layouts/main.twig" %}

{% block content %}

    <!-- Cabeçalho -->
        <section class="bg-gradient-to-br from-primary/10 via-background to-accent/5 px-4 py-12">
            <div class="container mx-auto">
                <h1 class="mb-4 text-4xl font-bold lg:text-5xl">Entre em Contato com a Saeld Auto</h1>
                <p class="text-lg text-muted-foreground">Estamos aqui para ajudar. Fale conosco!</p>
            </div>
        </section>

    <!-- Secção de Contacto -->
        <section class="px-4 py-12">
            <div class="container mx-auto">
                <div class="grid gap-8 lg:grid-cols-3">
                    <!-- Formulário de Contacto -->
                    <div class="lg:col-span-2">
                        <div class="rounded-lg border border-border bg-card p-8">
                            <h2 class="mb-6 text-2xl font-bold">Envie uma Mensagem</h2>
                            <form id="contact-form" class="space-y-6">
                                <div class="grid gap-6 sm:grid-cols-2">
                                    <div>
                                        <label for="name" class="mb-2 block text-sm font-medium">Nome Completo</label>
                                        <input type="text" id="name" name="name" required class="w-full rounded-lg border border-input bg-background px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-ring" placeholder="Seu nome">
                                    </div>
                                    <div>
                                        <label for="email" class="mb-2 block text-sm font-medium">Email</label>
                                        <input type="email" id="email" name="email" required class="w-full rounded-lg border border-input bg-background px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-ring" placeholder="seu@email.com">
                                    </div>
                                </div>
                                <div class="grid gap-6 sm:grid-cols-2">
                                    <div>
                                        <label for="phone" class="mb-2 block text-sm font-medium">Telefone</label>
                                        <input type="tel" id="phone" name="phone" class="w-full rounded-lg border border-input bg-background px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-ring" placeholder="+244 944 921 970">
                                    </div>
                                    <div>
                                        <label for="subject" class="mb-2 block text-sm font-medium">Assunto</label>
                                        <select id="subject" name="subject" required class="w-full rounded-lg border border-input bg-background px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-ring">
                                            <option value="">Selecione...</option>
                                            <option value="info">Informações Gerais</option>
                                            <option value="vehicle">Sobre um Automóvel</option>
                                            <option value="testdrive">Agendar Test Drive</option>
                                            <option value="financing">Financiamento</option>
                                            <option value="other">Outro</option>
                                        </select>
                                    </div>
                                </div>
                                <div>
                                    <label for="message" class="mb-2 block text-sm font-medium">Mensagem</label>
                                    <textarea id="message" name="message" rows="6" required class="w-full rounded-lg border border-input bg-background px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-ring" placeholder="Como podemos ajudar?"></textarea>
                                </div>
                                <div class="flex items-start gap-3">
                                    <input type="checkbox" id="privacy" name="privacy" required class="mt-1 h-4 w-4 rounded border-input text-primary focus:ring-2 focus:ring-ring">
                                    <label for="privacy" class="text-sm text-muted-foreground">
                                        Concordo com a <a href="#" class="text-primary hover:underline">política de privacidade</a> e autorizo o contacto
                                    </label>
                                </div>
                                <button type="submit" class="inline-flex w-full items-center justify-center rounded-lg bg-primary px-6 py-3 text-base font-medium text-primary-foreground transition-colors hover:bg-primary/90 sm:w-auto">
                                    <svg class="mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                    </svg>
                                    Enviar Mensagem
                                </button>
                            </form>
                            <div id="form-success" class="mt-6 hidden rounded-lg bg-primary/10 p-4 text-primary">
                                <div class="flex items-center gap-3">
                                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                                    </svg>
                                    <span class="font-medium">Mensagem enviada com sucesso! Entraremos em contato em breve.</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Informação de Contacto -->
                    <div class="space-y-6">
                        <!-- Ações Rápidas -->
                        <div class="rounded-lg border border-border bg-card p-6">
                            <h3 class="mb-4 text-lg font-bold">Ações Rápidas</h3>
                            <div class="space-y-3">
                                <a href="tel:+244944921970" class="flex items-center gap-3 rounded-lg border border-border bg-background p-4 transition-colors hover:bg-muted">
                                    <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10">
                                        <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                                        </svg>
                                    </div>
                                    <div>
                                        <div class="text-sm font-medium">Ligar Agora</div>
                                        <div class="text-xs text-muted-foreground">+244 936 145 154</div>
                                    </div>
                                </a>
                                
                            </div>
                        </div>

                        <!-- Detalhes de Contacto -->
                        <div class="rounded-lg border border-border bg-card p-6">
                            <h3 class="mb-4 text-lg font-bold">Informações de Contato</h3>
                            <div class="space-y-4">
                                <div class="flex items-start gap-3">
                                    <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    </svg>
                                    <div>
                                        <div class="font-medium">Endereço</div>
                                        <div class="text-sm text-muted-foreground">Município do Cazenga<br>Luanda, Angola</div>
                                    </div>
                                </div>
                                <div class="flex items-start gap-3">
                                    <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                                    </svg>
                                    <div>
                                        <div class="font-medium">Telefone</div>
                                        <div class="text-sm text-muted-foreground">+244 936 145 154</div>
                                    </div>
                                </div>
                                <div class="flex items-start gap-3">
                                    <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                    </svg>
                                    <div>
                                        <div class="font-medium">Email</div>
                                        <div class="text-sm text-muted-foreground">saeldauto@gmail.com</div>
                                    </div>
                                </div>
                                <div class="flex items-start gap-3">
                                    <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                    </svg>
                                    <div>
                                        <div class="font-medium">Horário</div>
                                        <div class="text-sm text-muted-foreground">
                                            Seg-Sex: 9h - 19h<br>
                                            Sábado: 10h - 18h<br>
                                            Domingo: Fechado
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Placeholder do Mapa -->
                        <div class="overflow-hidden rounded-lg border border-border">
                            <div class="aspect-square bg-muted">
                                <img src="/assets/site/images/lisbon-map-location-pin.jpg" alt="Localização" class="h-full w-full object-cover">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

<script src="assets/js/contato.js"></script>

  {% endblock %}
