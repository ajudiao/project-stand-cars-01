{% extends "layouts/main.twig" %}

{% block content %}

    <!-- Conteúdo Principal -->
    
    <!-- Secção Hero -->
        <section class="relative overflow-hidden bg-gradient-to-br from-background via-background to-muted/30 px-4 py-20 lg:py-32">
            <div class="container mx-auto">
                <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
                    <div class="flex flex-col justify-center">
                        <span class="mb-4 inline-flex w-fit items-center gap-1 rounded-full bg-accent/10 px-3 py-1 text-sm font-medium text-accent">
                            <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                            </svg>
                            Feito para você
                        </span>
                        <h1 class="mb-6 text-4xl font-bold leading-tight tracking-tight lg:text-6xl">
                            {% if heroCar %}
                                {{ heroCar.marca_nome }} {{ heroCar.modelo }}
                            {% else %}
                                Encontre o automóvel perfeito na Saeld Auto
                            {% endif %}
                        </h1>
                        <p class="mb-8 text-lg leading-relaxed text-muted-foreground lg:text-xl">
                            {% if heroCar and heroCar.descricao %}
                                {{ heroCar.descricao|slice(0, 160) }}...
                            {% else %}
                                Oferecemos automóveis que aliam qualidade, segurança e confiabilidade em Luanda. Encontre a solução ideal para sua mobilidade pessoal e familiar.
                            {% endif %}
                        </p>
                        <div class="flex flex-col gap-4 sm:flex-row">
                            {% if heroCar %}
                                <a href="/veiculos/{{ heroCar.id }}" class="group inline-flex items-center justify-center rounded-lg bg-primary px-6 py-3 text-base font-medium text-primary-foreground transition-colors hover:bg-primary/90">
                                    Ver Detalhes do Destaque
                                    <svg class="ml-2 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                    </svg>
                                </a>
                            {% else %}
                                <a href="{{ url('recomendacao') }}" class="group inline-flex items-center justify-center rounded-lg bg-primary px-6 py-3 text-base font-medium text-primary-foreground transition-colors hover:bg-primary/90">
                                    <svg class="mr-2 h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                    </svg>
                                    Recomendação
                                    <svg class="ml-2 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                    </svg>
                                </a>
                            {% endif %}
                            <a href="{{ url('veiculos') }}" class="inline-flex items-center justify-center rounded-lg border border-border bg-background px-6 py-3 text-base font-medium transition-colors hover:bg-muted">
                                <svg class="mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                                </svg>
                                Explorar Automóveis
                            </a>
                        </div>
                    </div>
                    <div class="relative">
                        <div class="relative aspect-[4/3] overflow-hidden rounded-2xl border border-border bg-muted shadow-2xl">
                            {% if heroCar %}
                                <img src="{{ carImage(heroCar.foto) }}" alt="{{ heroCar.marca_nome }} {{ heroCar.modelo }}" class="h-full w-full object-cover">
                            {% else %}
                                <img src="/assets/site/images/modern-luxury-car-showroom-automotive-technology.jpg" alt="Showroom Saeld Auto" class="h-full w-full object-cover">
                            {% endif %}
                        </div>
                        <div class="absolute -bottom-6 -left-6 rounded-xl border border-border bg-card p-4 shadow-lg">
                            <div class="flex items-center gap-3">
                                <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-primary/10">
                                    <svg class="h-6 w-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                                    </svg>
                                </div>
                                <div>
                                    <div class="text-2xl font-bold">98%</div>
                                    <div class="text-sm text-muted-foreground">Satisfação</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

    <!-- Secção de Estatísticas -->
        <section class="border-y border-border bg-muted/30 px-4 py-12">
            <div class="container mx-auto">
                <div class="grid grid-cols-2 gap-8 lg:grid-cols-4">
                    <div class="text-center">
                        <div class="mb-2 text-4xl font-bold text-primary lg:text-5xl">50+</div>
                        <div class="text-sm text-muted-foreground lg:text-base">Automóveis Disponíveis</div>
                    </div>
                    <div class="text-center">
                        <div class="mb-2 text-4xl font-bold text-primary lg:text-5xl">200+</div>
                        <div class="text-sm text-muted-foreground lg:text-base">Clientes Satisfeitos</div>
                    </div>
                    <div class="text-center">
                        <div class="mb-2 text-4xl font-bold text-primary lg:text-5xl">98%</div>
                        <div class="text-sm text-muted-foreground lg:text-base">Taxa de Satisfação</div>
                    </div>
                    <div class="text-center">
                        <div class="mb-2 text-4xl font-bold text-primary lg:text-5xl">7+</div>
                        <div class="text-sm text-muted-foreground lg:text-base">Anos de Experiência</div>
                    </div>
                </div>
            </div>
        </section>

    <!-- Veículos em Destaque -->
        <section class="px-4 py-20">
            <div class="container mx-auto">
                <div class="mb-12 text-center">
                    <h2 class="mb-4 text-3xl font-bold lg:text-4xl">Automóveis em Destaque</h2>
                    <p class="text-lg text-muted-foreground">Seleção premium dos nossos melhores automóveis disponíveis na Saeld Auto</p>
                </div>
                <div id="featured-vehicles" class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
                    {% for vehicle in featuredCars %}
                        <div class="group overflow-hidden rounded-lg border border-border bg-card transition-shadow hover:shadow-lg fade-in">
                            <div class="relative aspect-[4/3] overflow-hidden">
                                <img src="{{ carImage(vehicle.foto) }}" alt="{{ vehicle.marca_nome }} {{ vehicle.modelo }}" class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105">
                                <span class="absolute right-4 top-4 rounded-full bg-primary px-3 py-1 text-xs font-medium text-primary-foreground">
                                    {{ vehicle.status }}
                                </span>
                            </div>
                            <div class="p-6">
                                <div class="mb-2 flex items-start justify-between">
                                    <div>
                                        <h3 class="text-xl font-bold">{{ vehicle.marca_nome }} {{ vehicle.modelo }}</h3>
                                        <p class="text-sm text-muted-foreground">{{ vehicle.ano }}</p>
                                    </div>
                                    <div class="text-right">
                                        <div class="text-2xl font-bold text-primary">{{ vehicle.preco|number_format(0, ',', '.') }} Kzs</div>
                                    </div>
                                </div>
                                <div class="mb-4 flex flex-wrap gap-2">
                                    <span class="rounded-full bg-secondary/10 px-3 py-1 text-xs font-medium text-secondary-foreground">{{ vehicle.transmissao }}</span>
                                    <span class="rounded-full bg-secondary/10 px-3 py-1 text-xs font-medium text-secondary-foreground">{{ vehicle.combustivel }}</span>
                                    <span class="rounded-full bg-secondary/10 px-3 py-1 text-xs font-medium text-secondary-foreground">{{ vehicle.quilometragem|number_format(0, ',', '.') }} km</span>
                                </div>
                                <a href="/veiculos/{{ vehicle.id }}" class="inline-flex w-full items-center justify-center rounded-lg border border-border bg-transparent px-4 py-2 text-sm font-medium transition-colors hover:bg-muted">
                                    Ver Detalhes
                                    <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                    </svg>
                                </a>
                            </div>
                        </div>
                    {% else %}
                        <p class="col-span-full text-center text-muted-foreground">Nenhum veículo em destaque no momento.</p>
                    {% endfor %}
                </div>
                <div class="mt-12 text-center">
                    <a href="{{ url('veiculos') }}" class="inline-flex items-center justify-center rounded-lg border border-border bg-background px-6 py-3 text-base font-medium transition-colors hover:bg-muted">
                        Ver Todos os Veículos
                        <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                    </a>
                </div>
            </div>
        </section>

    <!-- CTA Escolha do Carro -->
<section class="px-4 py-20">
    <div class="container mx-auto">
        <div class="overflow-hidden rounded-2xl border-2 border-primary/20 bg-gradient-to-br from-primary/5 via-background to-accent/5 p-8 lg:p-12">
            <div class="grid gap-8 lg:grid-cols-2 lg:gap-12">
                
                <!-- Texto -->
                <div class="flex flex-col justify-center">
                    <div class="mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-primary/10">
                        <svg class="h-8 w-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 13l4-4m0 0l4 4m-4-4v12"/>
                        </svg>
                    </div>

                    <h2 class="mb-4 text-3xl font-bold lg:text-4xl">
                        Ainda não encontrou o carro ideal?
                    </h2>

                    <p class="mb-8 text-lg text-muted-foreground">
                        Fale com a nossa equipa e ajudamos você a encontrar o carro perfeito, dentro do seu orçamento e necessidade.
                    </p>

                    <div class="flex flex-wrap gap-4">
                        <a href="{{ url('veiculos') }}" class="inline-flex items-center justify-center rounded-lg bg-primary px-8 py-4 text-lg font-medium text-primary-foreground transition-colors hover:bg-primary/90">
                            Ver Stock
                        </a>

                        <a href="{{ url('contato') }}" class="inline-flex items-center justify-center rounded-lg border border-primary px-8 py-4 text-lg font-medium text-primary transition-colors hover:bg-primary/10">
                            Falar com Vendedor
                        </a>
                    </div>
                </div>

                <!-- Imagem -->
                <div class="relative hidden lg:block">
                    <div class="aspect-square overflow-hidden rounded-2xl border border-border bg-muted">
                            <img src="/assets/site/images/ai-technology-automotive-interface-futuristic.jpg" alt="IA na Saeld Auto" class="h-full w-full object-cover">
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>


    

{% endblock %}
