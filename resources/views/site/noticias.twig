    {% extends "layouts/main.twig" %}

{% block content %}

    <!-- Cabeçalho -->
        <section class="bg-gradient-to-br from-primary/10 via-background to-accent/5 px-4 pt-20 py-12">
            <div class="container mx-auto">
                <h1 class="mb-4 text-4xl font-bold lg:text-5xl">Notícias e Artigos</h1>
                <p class="text-lg text-muted-foreground">Fique por dentro das últimas novidades do mundo automóvel</p>
            </div>
        </section>

    <!-- Secção de Notícias -->
        <section class="px-4 py-12">
            <div class="container mx-auto">
                <!-- Filtro de Categoria -->
                <div class="mb-8 flex flex-wrap gap-2">
                    <button class="category-btn active rounded-full border border-border bg-primary px-4 py-2 text-sm font-medium text-primary-foreground transition-colors" data-category="Todos">
                        Todos
                    </button>
                    <button class="category-btn rounded-full border border-border bg-background px-4 py-2 text-sm font-medium transition-colors hover:bg-muted" data-category="Elétricos">
                        Elétricos
                    </button>
                    <button class="category-btn rounded-full border border-border bg-background px-4 py-2 text-sm font-medium transition-colors hover:bg-muted" data-category="Híbridos">
                        Híbridos
                    </button>
                    <button class="category-btn rounded-full border border-border bg-background px-4 py-2 text-sm font-medium transition-colors hover:bg-muted" data-category="Manutenção">
                        Manutenção
                    </button>
                    <button class="category-btn rounded-full border border-border bg-background px-4 py-2 text-sm font-medium transition-colors hover:bg-muted" data-category="Tendências">
                        Tendências
                    </button>
                    <button class="category-btn rounded-full border border-border bg-background px-4 py-2 text-sm font-medium transition-colors hover:bg-muted" data-category="Guias">
                        Guias
                    </button>
                </div>

                <!-- Artigo em Destaque -->
                <div id="featured-article" class="mb-12">
                    <!-- Será carregado pelo JavaScript -->
                </div>

                <!-- Grid de Artigos -->
                <div id="articles-grid" class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
                    {% for noticia in noticias %}
                    <article class="group overflow-hidden rounded-2xl border border-border bg-card shadow-sm transition-all hover:shadow-lg">
                        <div class="aspect-[16/10] overflow-hidden">
                            <img src="{% if noticia.imagem_capa %}/uploads/news/{{ noticia.imagem_capa }}{% else %}https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?w=400&h=250&fit=crop{% endif %}" alt="{{ noticia.titulo }}" class="h-full w-full object-cover transition-transform group-hover:scale-105">
                        </div>
                        <div class="p-6">
                            <div class="mb-2 flex items-center gap-2 text-sm text-muted-foreground">
                                <time datetime="{{ noticia.data_publicacao }}">{{ noticia.data_publicacao | date('d/m/Y') }}</time>
                                {% if noticia.autor %}
                                <span>•</span>
                                <span>{{ noticia.autor }}</span>
                                {% endif %}
                            </div>
                            <h3 class="mb-3 text-xl font-bold leading-tight">
                                <a href="/noticias/{{ noticia.slug }}" class="transition-colors hover:text-primary">{{ noticia.titulo }}</a>
                            </h3>
                            {% if noticia.resumo %}
                            <p class="text-muted-foreground">{{ noticia.resumo | slice(0, 120) }}...</p>
                            {% endif %}
                            <a href="/noticias/{{ noticia.slug }}" class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-primary transition-colors hover:text-primary/80">
                                Ler mais
                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                </svg>
                            </a>
                        </div>
                    </article>
                    {% endfor %}
                </div>
            </div>
        </section>
    <script src="assets/js/noticias.js"></script>


{% endblock %}