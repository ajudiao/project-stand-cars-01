{% extends "layouts/main.twig" %}

{% block content %}
    <main class="min-h-screen">
        <section class="bg-gradient-to-br from-primary/10 via-background to-accent/5 px-4 py-12">
            <div class="container mx-auto">
                <div class="mb-6">
                    <a href="{{ url('veiculos') }}" class="inline-flex items-center text-sm text-muted-foreground transition-colors hover:text-primary">
                        <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                        </svg>
                        Voltar aos automóveis
                    </a>
                </div>

                {% if not veiculo %}
                    <div class="rounded-lg border border-border bg-card p-12 text-center">
                        <h1 class="mb-4 text-3xl font-bold">Automóvel não encontrado</h1>
                        <p class="mb-6 text-muted-foreground">O automóvel que procura não existe ou foi removido.</p>
                        <a href="{{ url('veiculos') }}" class="inline-flex items-center justify-center rounded-lg bg-primary px-6 py-3 text-base font-medium text-primary-foreground transition-colors hover:bg-primary/90">Ver Todos os Veículos</a>
                    </div>
                {% else %}
                    <div class="grid gap-8 lg:grid-cols-3">
                        <div class="lg:col-span-2">
                            <div class="mb-8 grid gap-4">
                                <div class="aspect-[16/10] overflow-hidden rounded-2xl border border-border bg-muted">
                                    <img src="{{ carImage(veiculo.foto ?? veiculo.imagens[0] ?? null) }}" alt="{{ veiculo.marca_nome }} {{ veiculo.modelo }}" class="h-full w-full object-cover">
                                </div>

                                {% if veiculo.imagens is not empty and veiculo.imagens|length > 1 %}
                                    <div class="rounded-2xl border border-border bg-card p-4">
                                        <h2 class="mb-4 text-lg font-bold">Mais imagens</h2>
                                        <div class="grid gap-4 sm:grid-cols-3">
                                            {% for imagem in veiculo.imagens|slice(1) %}
                                                <div class="overflow-hidden rounded-2xl border border-border bg-muted">
                                                    <img src="{{ carImage(imagem) }}" alt="{{ veiculo.marca_nome }} {{ veiculo.modelo }}" class="h-32 w-full object-cover">
                                                </div>
                                            {% endfor %}
                                        </div>
                                    </div>
                                {% endif %}
                            </div>

                            <div class="mb-8 rounded-2xl border border-border bg-card p-6">
                                <div class="mb-4 flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                                    <div>
                                        <h1 class="mb-2 text-3xl font-bold">{{ veiculo.marca_nome }} {{ veiculo.modelo }}</h1>
                                        <p class="text-lg text-muted-foreground">{{ veiculo.categoria_nome ?? 'Sem categoria' }} • {{ veiculo.ano }}</p>
                                    </div>
                                    <span class="inline-flex items-center rounded-full bg-primary px-4 py-2 text-sm font-medium text-primary-foreground">{{ veiculo.status }}</span>
                                </div>
                                <div class="text-4xl font-bold text-primary">{{ veiculo.preco | number_format(0, ',', '.') }} Kzs</div>
                            </div>

                            <div class="mb-8 rounded-2xl border border-border bg-card p-6">
                                <h2 class="mb-4 text-xl font-bold">Especificações</h2>
                                <div class="grid gap-4 sm:grid-cols-2">
                                    <div class="rounded-2xl bg-background p-4">
                                        <div class="text-sm text-muted-foreground">Ano</div>
                                        <div class="mt-1 font-semibold">{{ veiculo.ano }}</div>
                                    </div>
                                    <div class="rounded-2xl bg-background p-4">
                                        <div class="text-sm text-muted-foreground">Combustível</div>
                                        <div class="mt-1 font-semibold">{{ veiculo.combustivel }}</div>
                                    </div>
                                    <div class="rounded-2xl bg-background p-4">
                                        <div class="text-sm text-muted-foreground">Transmissão</div>
                                        <div class="mt-1 font-semibold">{{ veiculo.transmissao }}</div>
                                    </div>
                                    <div class="rounded-2xl bg-background p-4">
                                        <div class="text-sm text-muted-foreground">Quilometragem</div>
                                        <div class="mt-1 font-semibold">{{ veiculo.quilometragem | number_format(0, ',', '.') }} km</div>
                                    </div>
                                    <div class="rounded-2xl bg-background p-4">
                                        <div class="text-sm text-muted-foreground">Cor</div>
                                        <div class="mt-1 font-semibold">{{ veiculo.cor }}</div>
                                    </div>
                                    <div class="rounded-2xl bg-background p-4">
                                        <div class="text-sm text-muted-foreground">Destaque</div>
                                        <div class="mt-1 font-semibold">{{ veiculo.destaque ? 'Sim' : 'Não' }}</div>
                                    </div>
                                </div>
                            </div>

                            <div class="rounded-2xl border border-border bg-card p-6">
                                <h2 class="mb-4 text-xl font-bold">Descrição</h2>
                                <p class="leading-relaxed text-muted-foreground">{{ veiculo.descricao | default('Sem descrição disponível para este veículo.') }}</p>
                            </div>
                        </div>

                        <aside class="lg:col-span-1">
                            <div class="sticky top-20 space-y-6">
                                <div class="rounded-2xl border border-border bg-card p-6">
                                    <h3 class="mb-4 text-lg font-bold">Interessado?</h3>
                                    <div class="space-y-3">
                                        <a href="{{ url('contato') }}" class="flex w-full items-center justify-center rounded-lg bg-primary px-4 py-3 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90">Enviar Mensagem</a>
                                        <a href="tel:+351211234567" class="flex w-full items-center justify-center rounded-lg border border-border bg-background px-4 py-3 text-sm font-medium transition-colors hover:bg-muted">Ligar Agora</a>
                                    </div>
                                </div>

                                <div class="rounded-2xl border border-border bg-card p-6">
                                    <h3 class="mb-4 text-lg font-bold">Garantias</h3>
                                    <ul class="space-y-3 text-sm text-muted-foreground">
                                        <li>Inspeção completa</li>
                                        <li>Histórico verificado</li>
                                        <li>Atendimento personalizado</li>
                                    </ul>
                                </div>
                            </div>
                        </aside>
                    </div>
                {% endif %}
            </div>
        </section>
    </main>
{% endblock %}
